@page "/players"
@inject HttpClient Http
@using MVDC.Shared.Models

<h3>Players</h3>

<button class="btn btn-primary mb-3" @onclick="() => ShowForm(null)">Add Player</button>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(editingPlayer?.Id != null ? "Edit" : "New") Player</h5>
            <div class="mb-2">
                <label>Name</label>
                <input class="form-control" @bind="formPlayer.Name" />
            </div>
            <div class="mb-2">
                <label>Date of Birth</label>
                <input type="date" class="form-control" @bind="formPlayer.DateOfBirth" />
            </div>
            <div class="mb-2">
                <label>Position</label>
                <input class="form-control" @bind="formPlayer.Position" />
            </div>
            <button class="btn btn-success me-2" @onclick="SavePlayer">Save</button>
            <button class="btn btn-secondary" @onclick="() => showForm = false">Cancel</button>
        </div>
    </div>
}

@if (players == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>Name</th><th>Date of Birth</th><th>Position</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var p in players)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.DateOfBirth.ToShortDateString()</td>
                    <td>@p.Position</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => ShowForm(p)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeletePlayer(p.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Player>? players;
    private bool showForm = false;
    private Player formPlayer = new();
    private Player? editingPlayer;

    protected override async Task OnInitializedAsync() => await LoadPlayers();

    private async Task LoadPlayers()
    {
        players = await Http.GetFromJsonAsync<List<Player>>("api/players");
    }

    private void ShowForm(Player? player)
    {
        editingPlayer = player;
        formPlayer = player != null ? new Player { Id = player.Id, Name = player.Name, DateOfBirth = player.DateOfBirth, Position = player.Position, TeamId = player.TeamId } : new Player();
        showForm = true;
    }

    private async Task SavePlayer()
    {
        if (editingPlayer != null)
            await Http.PutAsJsonAsync($"api/players/{formPlayer.Id}", formPlayer);
        else
            await Http.PostAsJsonAsync("api/players", formPlayer);
        showForm = false;
        await LoadPlayers();
    }

    private async Task DeletePlayer(string id)
    {
        await Http.DeleteAsync($"api/players/{id}");
        await LoadPlayers();
    }
}
