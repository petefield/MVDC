@page "/players"
@attribute [Authorize]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Players | MVGFC</PageTitle>

<div class="container px-3 py-3">
<h3>Players</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<button class="btn btn-primary mb-3" @onclick="() => ShowForm(null)">Add Player</button>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(editingPlayer?.Id != null ? "Edit" : "New") Player</h5>
            <EditForm Model="formPlayer" OnValidSubmit="SavePlayer">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="mb-2">
                    <label>Name</label>
                    <InputText class="form-control" @bind-Value="formPlayer.Name" />
                    <ValidationMessage For="() => formPlayer.Name" />
                </div>
                <div class="mb-2">
                    <label>Date of Birth</label>
                    <InputDate class="form-control" @bind-Value="formPlayer.DateOfBirth" />
                    <ValidationMessage For="() => formPlayer.DateOfBirth" />
                </div>
                <div class="mb-2">
                    <label>Position</label>
                    <InputText class="form-control" @bind-Value="formPlayer.Position" />
                    <ValidationMessage For="() => formPlayer.Position" />
                </div>
                <button type="submit" class="btn btn-success me-2">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (players == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>Name</th><th>Date of Birth</th><th>Position</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var p in players)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.DateOfBirth.ToShortDateString()</td>
                    <td>@p.Position</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => ShowForm(p)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeletePlayer(p.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</div>

@code {
    private List<Player>? players;
    private bool showForm = false;
    private Player formPlayer = new();
    private Player? editingPlayer;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await LoadPlayers();

    private async Task LoadPlayers()
    {
        try
        {
            players = await Http.GetFromJsonAsync<List<Player>>("api/players");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load players: {ex.Message}";
        }
    }

    private void ShowForm(Player? player)
    {
        editingPlayer = player;
        formPlayer = player != null ? new Player { Id = player.Id, Name = player.Name, DateOfBirth = player.DateOfBirth, Position = player.Position, TeamId = player.TeamId } : new Player();
        showForm = true;
    }

    private async Task SavePlayer()
    {
        try
        {
            HttpResponseMessage response;
            if (editingPlayer != null)
                response = await Http.PutAsJsonAsync($"api/players/{formPlayer.Id}", formPlayer);
            else
                response = await Http.PostAsJsonAsync("api/players", formPlayer);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to save player (HTTP {(int)response.StatusCode}).";
                return;
            }

            showForm = false;
            await LoadPlayers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save player: {ex.Message}";
        }
    }

    private async Task DeletePlayer(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this player?");
        if (!confirmed) return;

        try
        {
            var response = await Http.DeleteAsync($"api/players/{id}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to delete player (HTTP {(int)response.StatusCode}).";
                return;
            }
            await LoadPlayers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete player: {ex.Message}";
        }
    }
}
