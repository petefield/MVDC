@page "/coaches"
@inject HttpClient Http
@using MVDC.Shared.Models

<h3>Coaches</h3>

<button class="btn btn-primary mb-3" @onclick="() => ShowForm(null)">Add Coach</button>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(editingCoach?.Id != null ? "Edit" : "New") Coach</h5>
            <div class="mb-2">
                <label>Name</label>
                <input class="form-control" @bind="formCoach.Name" />
            </div>
            <div class="mb-2">
                <label>Email</label>
                <input class="form-control" @bind="formCoach.Email" />
            </div>
            <div class="mb-2">
                <label>Phone</label>
                <input class="form-control" @bind="formCoach.Phone" />
            </div>
            <button class="btn btn-success me-2" @onclick="SaveCoach">Save</button>
            <button class="btn btn-secondary" @onclick="() => showForm = false">Cancel</button>
        </div>
    </div>
}

@if (coaches == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Phone</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var c in coaches)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.Email</td>
                    <td>@c.Phone</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => ShowForm(c)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteCoach(c.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Coach>? coaches;
    private bool showForm = false;
    private Coach formCoach = new();
    private Coach? editingCoach;

    protected override async Task OnInitializedAsync() => await LoadCoaches();

    private async Task LoadCoaches()
    {
        coaches = await Http.GetFromJsonAsync<List<Coach>>("api/coaches");
    }

    private void ShowForm(Coach? coach)
    {
        editingCoach = coach;
        formCoach = coach != null ? new Coach { Id = coach.Id, Name = coach.Name, Email = coach.Email, Phone = coach.Phone } : new Coach();
        showForm = true;
    }

    private async Task SaveCoach()
    {
        if (editingCoach != null)
            await Http.PutAsJsonAsync($"api/coaches/{formCoach.Id}", formCoach);
        else
            await Http.PostAsJsonAsync("api/coaches", formCoach);
        showForm = false;
        await LoadCoaches();
    }

    private async Task DeleteCoach(string id)
    {
        await Http.DeleteAsync($"api/coaches/{id}");
        await LoadCoaches();
    }
}
