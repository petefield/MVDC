@page "/parents"
@attribute [Authorize]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Parents | MVGFC</PageTitle>

<div class="container px-3 py-3">
<h3>Parents</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<button class="btn btn-primary mb-3" @onclick="() => ShowForm(null)">Add Parent</button>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(editingParent?.Id != null ? "Edit" : "New") Parent</h5>
            <EditForm Model="formParent" OnValidSubmit="SaveParent">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="mb-2">
                    <label>Name</label>
                    <InputText class="form-control" @bind-Value="formParent.Name" />
                    <ValidationMessage For="() => formParent.Name" />
                </div>
                <div class="mb-2">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="formParent.Email" />
                    <ValidationMessage For="() => formParent.Email" />
                </div>
                <div class="mb-2">
                    <label>Phone</label>
                    <InputText class="form-control" @bind-Value="formParent.Phone" />
                    <ValidationMessage For="() => formParent.Phone" />
                </div>
                <div class="mb-2">
                    <label>Linked Players</label>
                    @foreach (var p in allPlayers ?? new List<Player>())
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="parentplayer_@p.Id"
                                   checked="@formParent.PlayerIds.Contains(p.Id)"
                                   @onchange="e => TogglePlayer(p.Id, (bool)e.Value!)" />
                            <label class="form-check-label" for="parentplayer_@p.Id">@p.Name</label>
                        </div>
                    }
                </div>
                <button type="submit" class="btn btn-success me-2">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (parents == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Phone</th><th>Players</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var parent in parents)
            {
                <tr>
                    <td>@parent.Name</td>
                    <td>@parent.Email</td>
                    <td>@parent.Phone</td>
                    <td>@parent.PlayerIds.Count</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => ShowForm(parent)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteParent(parent.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
</div>

@code {
    private List<Parent>? parents;
    private List<Player>? allPlayers;
    private bool showForm = false;
    private Parent formParent = new();
    private Parent? editingParent;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.WhenAll(LoadParents(), LoadPlayers());
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
        }
    }

    private async Task LoadParents() => parents = await Http.GetFromJsonAsync<List<Parent>>("api/parents");
    private async Task LoadPlayers() => allPlayers = await Http.GetFromJsonAsync<List<Player>>("api/players");

    private void ShowForm(Parent? parent)
    {
        editingParent = parent;
        formParent = parent != null ? new Parent { Id = parent.Id, Name = parent.Name, Email = parent.Email, Phone = parent.Phone, PlayerIds = new List<string>(parent.PlayerIds) } : new Parent();
        showForm = true;
    }

    private void TogglePlayer(string playerId, bool isChecked)
    {
        if (isChecked && !formParent.PlayerIds.Contains(playerId))
            formParent.PlayerIds.Add(playerId);
        else if (!isChecked)
            formParent.PlayerIds.Remove(playerId);
    }

    private async Task SaveParent()
    {
        try
        {
            HttpResponseMessage response;
            if (editingParent != null)
                response = await Http.PutAsJsonAsync($"api/parents/{formParent.Id}", formParent);
            else
                response = await Http.PostAsJsonAsync("api/parents", formParent);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to save parent (HTTP {(int)response.StatusCode}).";
                return;
            }

            showForm = false;
            await LoadParents();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save parent: {ex.Message}";
        }
    }

    private async Task DeleteParent(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this parent?");
        if (!confirmed) return;

        try
        {
            var response = await Http.DeleteAsync($"api/parents/{id}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to delete parent (HTTP {(int)response.StatusCode}).";
                return;
            }
            await LoadParents();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete parent: {ex.Message}";
        }
    }
}
