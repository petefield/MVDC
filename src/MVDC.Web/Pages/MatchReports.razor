@page "/matchreports"
@page "/matchreports/{PreselectedFixtureId}"
@attribute [Authorize]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Match Reports | MVGFC</PageTitle>

<div class="container px-3 py-3">
<h3>Match Reports</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="d-flex align-items-center mb-3 gap-3">
    <button class="btn btn-primary" @onclick="() => ShowForm(null)">Add Match Report</button>
    <div class="d-flex align-items-center gap-2">
        <label class="mb-0 fw-bold">Filter:</label>
        <select class="form-select" style="width: auto;" @bind="selectedTeamFilter">
            <option value="">All Teams</option>
            @foreach (var t in teams ?? new List<Team>())
            {
                <option value="@t.Id">@t.Name</option>
            }
        </select>
    </div>
</div>

@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@(editingReport?.Id != null ? "Edit" : "New") Match Report</h5>
            <EditForm Model="formReport" OnValidSubmit="SaveReport">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="mb-2">
                    <label>Fixture</label>
                    <InputSelect class="form-select" @bind-Value="formReport.FixtureId">
                        <option value="">-- Select Fixture --</option>
                        @foreach (var f in fixtures ?? new List<Fixture>())
                        {
                            <option value="@f.Id">@f.Opponent - @f.Date.ToString("dd MMM yyyy")</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => formReport.FixtureId" />
                </div>
                <div class="mb-2">
                    <label>Coach</label>
                    <InputSelect class="form-select" @bind-Value="formReport.CoachId">
                        <option value="">-- Select Coach --</option>
                        @foreach (var c in coaches ?? new List<Coach>())
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="row mb-2">
                    <div class="col">
                        <label>Home Score</label>
                        <InputNumber class="form-control" @bind-Value="formReport.HomeScore" />
                    </div>
                    <div class="col">
                        <label>Away Score</label>
                        <InputNumber class="form-control" @bind-Value="formReport.AwayScore" />
                    </div>
                </div>
                <div class="mb-2">
                    <label>Report</label>
                    <InputTextArea class="form-control" rows="5" @bind-Value="formReport.Report" />
                    <ValidationMessage For="() => formReport.Report" />
                </div>
                <div class="mb-2">
                    <label>Photo URLs (one per line)</label>
                    <InputTextArea class="form-control" rows="3" @bind-Value="photoUrlsText" />
                </div>
                <button type="submit" class="btn btn-success me-2">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">Cancel</button>
            </EditForm>
        </div>
    </div>
}

@if (reports == null)
{
    <p>Loading...</p>
}
else
{
    @foreach (var r in FilteredReports)
    {
        var fixture = fixtures?.FirstOrDefault(f => f.Id == r.FixtureId);
        var coach = coaches?.FirstOrDefault(c => c.Id == r.CoachId);
        var teamName = fixture != null ? teams?.FirstOrDefault(t => t.Id == fixture.TeamId)?.Name : null;
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center" role="button" @onclick="() => ToggleReport(r.Id)" style="cursor: pointer;">
                <strong>@(teamName ?? "Unknown Team") vs @(fixture?.Opponent ?? "Unknown") - @(fixture?.Date.ToString("dd MMM yyyy") ?? "")</strong>
                <span>
                    @if (r.HomeScore.HasValue && r.AwayScore.HasValue)
                    {
                        <span class="badge bg-primary me-2">@r.HomeScore - @r.AwayScore</span>
                    }
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => ShowForm(r)" @onclick:stopPropagation="true">Edit</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteReport(r.Id)" @onclick:stopPropagation="true">Delete</button>
                    <span class="ms-2">@(IsExpanded(r.Id) ? "\u25B2" : "\u25BC")</span>
                </span>
            </div>
            @if (IsExpanded(r.Id))
            {
                <div class="card-body">
                    <p class="text-muted">Coach: @(coach?.Name ?? r.CoachId)</p>
                    <div class="match-report-text">@r.Report</div>
                    @if (r.PhotoUrls.Any())
                    {
                        <div class="row">
                            @foreach (var url in r.PhotoUrls)
                            {
                                <div class="col-md-3 mb-2">
                                    <img src="@url" class="img-fluid rounded" alt="Match photo" />
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}
</div>

@code {
    private List<MatchReport>? reports;
    private List<Fixture>? fixtures;
    private List<Coach>? coaches;
    private List<Team>? teams;
    private bool showForm = false;
    private MatchReport formReport = new();
    private MatchReport? editingReport;
    private string photoUrlsText = "";
    private readonly HashSet<string> expandedReports = new();
    private string selectedTeamFilter = string.Empty;
    private string? errorMessage;

    private IEnumerable<MatchReport> FilteredReports
    {
        get
        {
            var ordered = (reports ?? []).OrderByDescending(x => x.CreatedAt);
            if (string.IsNullOrEmpty(selectedTeamFilter))
                return ordered;
            var fixtureIds = (fixtures ?? [])
                .Where(f => f.TeamId == selectedTeamFilter)
                .Select(f => f.Id)
                .ToHashSet();
            return ordered.Where(r => fixtureIds.Contains(r.FixtureId));
        }
    }

    private bool IsExpanded(string reportId) => expandedReports.Contains(reportId);

    private void ToggleReport(string reportId)
    {
        if (!expandedReports.Remove(reportId))
            expandedReports.Add(reportId);
    }

    [Parameter] public string? PreselectedFixtureId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.WhenAll(LoadReports(), LoadFixtures(), LoadCoaches(), LoadTeams());

            if (!string.IsNullOrEmpty(PreselectedFixtureId) && reports != null)
            {
                var existing = reports.FirstOrDefault(r => r.FixtureId == PreselectedFixtureId);
                if (existing != null)
                {
                    ShowForm(existing);
                }
                else
                {
                    ShowForm(null);
                    formReport.FixtureId = PreselectedFixtureId;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
        }
    }

    private async Task LoadReports() => reports = await Http.GetFromJsonAsync<List<MatchReport>>("api/matchreports");
    private async Task LoadFixtures() => fixtures = await Http.GetFromJsonAsync<List<Fixture>>("api/fixtures");
    private async Task LoadCoaches() => coaches = await Http.GetFromJsonAsync<List<Coach>>("api/coaches");
    private async Task LoadTeams() => teams = await Http.GetFromJsonAsync<List<Team>>("api/teams");

    private void ShowForm(MatchReport? report)
    {
        editingReport = report;
        formReport = report != null ? new MatchReport { Id = report.Id, FixtureId = report.FixtureId, CoachId = report.CoachId, Report = report.Report, HomeScore = report.HomeScore, AwayScore = report.AwayScore, PhotoUrls = new List<string>(report.PhotoUrls) } : new MatchReport();
        photoUrlsText = string.Join("\n", formReport.PhotoUrls);
        showForm = true;
    }

    private async Task SaveReport()
    {
        try
        {
            formReport.PhotoUrls = photoUrlsText.Split('\n', StringSplitOptions.RemoveEmptyEntries).Select(u => u.Trim()).ToList();
            HttpResponseMessage response;
            if (editingReport != null)
                response = await Http.PutAsJsonAsync($"api/matchreports/{formReport.Id}", formReport);
            else
                response = await Http.PostAsJsonAsync("api/matchreports", formReport);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to save match report (HTTP {(int)response.StatusCode}).";
                return;
            }

            showForm = false;
            await LoadReports();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save match report: {ex.Message}";
        }
    }

    private async Task DeleteReport(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this match report?");
        if (!confirmed) return;

        try
        {
            var response = await Http.DeleteAsync($"api/matchreports/{id}");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to delete match report (HTTP {(int)response.StatusCode}).";
                return;
            }
            await LoadReports();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete match report: {ex.Message}";
        }
    }
}
