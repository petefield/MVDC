@page "/"

<PageTitle>MVDC Football</PageTitle>

<h1>Welcome to MVDC Girls Football</h1>

<p>Use the navigation menu to manage your team.</p>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">&#x1F469;&#x200D;&#x26BD; Players</h5>
                <p class="card-text">Manage player profiles and team assignments.</p>
                <a href="players" class="btn btn-primary">Manage Players</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">&#x1F3C6; Teams</h5>
                <p class="card-text">Create teams and assign players and coaches.</p>
                <a href="teams" class="btn btn-primary">Manage Teams</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">&#x1F4C5; Fixtures</h5>
                <p class="card-text">View and manage upcoming fixtures.</p>
                <a href="fixtures" class="btn btn-primary">View Fixtures</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">&#x2705; Availability</h5>
                <p class="card-text">Parents can mark player availability for fixtures.</p>
                <a href="availability" class="btn btn-primary">Mark Availability</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">&#x1F4DD; Match Reports</h5>
                <p class="card-text">Coaches write match reports with photos.</p>
                <a href="matchreports" class="btn btn-primary">Match Reports</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">&#x1F46A; Parents</h5>
                <p class="card-text">Manage parent contacts and player links.</p>
                <a href="parents" class="btn btn-primary">Manage Parents</a>
            </div>
        </div>
    </div>
</div>

