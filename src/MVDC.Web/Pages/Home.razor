@page "/"
@inject HttpClient Http

<PageTitle>Mole Valley Girls FC | Girls football at its best</PageTitle>

<div class="hero-banner">
    <div class="hero-content">
        <h1>We're Mole Valley Girls U9</h1>
        <p>Welcome to our official website! We're a fun and friendly team dedicated to helping young girls develop their football skills and enjoy the game.</p>
    </div>
</div>

<div class="container">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
        </div>
    }

    <section class="match-reports-section">
        <h2 class="section-heading">Latest Match Reports</h2>

        @if (reports == null)
        {
            <p class="text-muted">Loading match reports...</p>
        }
        else if (!reports.Any())
        {
            <p class="text-muted">No match reports yet. <a href="matchreports">Add one</a>.</p>
        }
        else
        {
            <div class="match-reports-grid">
                @foreach (var r in reports.OrderByDescending(x => x.CreatedAt).Take(6))
                {

                    <div class="match-report-card">
                        <div class="match-report-header">
                            @{
                                var fixture = fixtures?.FirstOrDefault(f => f.Id == r.FixtureId);
                                var teamName = fixture != null
                                    ? teams?.FirstOrDefault(t => t.Id == fixture.TeamId)?.Name
                                    : null;
                            }
                            @if (teamName != null)
                            {
                                <span class="match-report-team">@teamName</span>
                            }
                            @if (fixture != null)
                            {
                                <span class="match-report-opponent">vs @fixture.Opponent</span>
                                <span class="match-report-date">@fixture.Date.ToString("dd MMM yyyy")</span>
                            }
                            @if (r.HomeScore.HasValue && r.AwayScore.HasValue)
                            {
                                <span class="match-score">@r.HomeScore &ndash; @r.AwayScore</span>
                            }
                        </div>

                        <p class="match-report-excerpt">
                            @(r.Report.Length > 180 ? r.Report[..180] + "..." : r.Report)
                        </p>
                    </div>
                }
            </div>

            @if (reports.Count > 6)
            {
                <div class="text-center mt-3">
                    <a href="matchreports" class="btn btn-primary">View All Match Reports</a>
                </div>
            }
        }
    </section>
</div>

@code {
    private List<MatchReport>? reports;
    private List<Fixture>? fixtures;
    private List<Team>? teams;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var reportsTask = Http.GetFromJsonAsync<List<MatchReport>>("api/matchreports");
            var fixturesTask = Http.GetFromJsonAsync<List<Fixture>>("api/fixtures");
            var teamsTask = Http.GetFromJsonAsync<List<Team>>("api/teams");
            await Task.WhenAll(reportsTask, fixturesTask, teamsTask);
            reports = await reportsTask ?? [];
            fixtures = await fixturesTask ?? [];
            teams = await teamsTask ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load data: {ex.Message}";
        }
    }
}
