@page "/"

<PageTitle>MVDC Girls FC</PageTitle>

<div class="hero-banner">
    <h1>MVDC Girls Football Club</h1>
    <p>Team management portal &mdash; manage players, fixtures, availability and match reports.</p>
</div>

<div class="row g-4">
    <div class="col-md-4 col-sm-6">
        <div class="card dashboard-card h-100">
            <div class="card-body d-flex flex-column">
                <span class="card-icon">&#x1F469;&#x200D;&#x26BD;</span>
                <h5 class="card-title">Players</h5>
                <p class="card-text text-muted flex-grow-1">Manage player profiles and team assignments.</p>
                <a href="players" class="btn btn-primary mt-2">Manage Players</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card dashboard-card h-100">
            <div class="card-body d-flex flex-column">
                <span class="card-icon">&#x1F3C6;</span>
                <h5 class="card-title">Teams</h5>
                <p class="card-text text-muted flex-grow-1">Create teams and assign players and coaches.</p>
                <a href="teams" class="btn btn-primary mt-2">Manage Teams</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card dashboard-card h-100">
            <div class="card-body d-flex flex-column">
                <span class="card-icon">&#x1F4C5;</span>
                <h5 class="card-title">Fixtures</h5>
                <p class="card-text text-muted flex-grow-1">View and manage upcoming fixtures.</p>
                <a href="fixtures" class="btn btn-primary mt-2">View Fixtures</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card dashboard-card h-100">
            <div class="card-body d-flex flex-column">
                <span class="card-icon">&#x2705;</span>
                <h5 class="card-title">Availability</h5>
                <p class="card-text text-muted flex-grow-1">Parents can mark player availability for fixtures.</p>
                <a href="availability" class="btn btn-primary mt-2">Mark Availability</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card dashboard-card h-100">
            <div class="card-body d-flex flex-column">
                <span class="card-icon">&#x1F4DD;</span>
                <h5 class="card-title">Match Reports</h5>
                <p class="card-text text-muted flex-grow-1">Coaches write match reports with photos.</p>
                <a href="matchreports" class="btn btn-primary mt-2">Match Reports</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-6">
        <div class="card dashboard-card h-100">
            <div class="card-body d-flex flex-column">
                <span class="card-icon">&#x1F46A;</span>
                <h5 class="card-title">Parents</h5>
                <p class="card-text text-muted flex-grow-1">Manage parent contacts and player links.</p>
                <a href="parents" class="btn btn-primary mt-2">Manage Parents</a>
            </div>
        </div>
    </div>
</div>
